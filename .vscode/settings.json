{
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true,
        "project/": true
    },
    "files.exclude": {
        "project/": true,
        "wrangler.jsonc": true,
        "package.json": true,
        "sitemap.xml": true,
        "robots.txt": true
    },
    "liveServer.settings.ignoreFiles": [
        "**/.git/**",
        ".git/**",
        "**/.vscode/**",
        ".vscode/**",
        "**/.DS_Store",
        "**/.DS_Store?",
        "**/._*",
        "**/.Spotlight-V100/**",
        "**/.Trashes/**",
        "**/node_modules/**",
        "node_modules/**",
        "**/content/**",
        "content/**",
        "**/assets/js/project-data.js",
        "assets/js/project-data.js",
        "**/dev/**",
        "dev/**",
        "**/.wrangler/**",
        ".wrangler/**",
        "sitemap.xml",
        "robots.txt",
        "package.json",
        "package-lock.json",
        "wrangler.jsonc",
        ".gitignore",
        "README.md"
    ],
    "liveServer.settings.wait": 1000,

    // --- Auto-Compilation Extensions Settings ---
    // Option 1: For "Trigger Task on Save" extension (ID: gardne.trigger-task-on-save)
    "triggerTaskOnSave.on": true,
    "triggerTaskOnSave.showNotifications": true,
    "triggerTaskOnSave.tasks": {
        "Build Project Pages": [
            "**/content/*.html",
            "**/assets/js/project-data.js"
        ]
    },

    // Option 2: For "Run on Save" extension (ID: emeraldwalk.runonsave)
    "emeraldwalk.runonsave": {
        "commands": [
            {
                "match": "content/.*\\.html$|assets/js/project-data\\.js$",
                "cmd": "python3 dev/generate.py"
            }
        ]
    }
}
