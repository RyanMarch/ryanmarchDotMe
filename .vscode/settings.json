{
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true,
        "project/": true
    },
    "files.exclude": {
        "project/": true,
        "wrangler.jsonc": true,
        "package.json": true,
        "sitemap.xml": true,
        "robots.txt": true
    },
    "liveServer.settings.ignoreFiles": [
        "**/.git/**",
        ".git/**",
        "**/.vscode/**",
        ".vscode/**",
        "**/.DS_Store",
        "**/.DS_Store?",
        "**/._*",
        "**/.Spotlight-V100/**",
        "**/.Trashes/**",
        "**/node_modules/**",
        "node_modules/**",
        "**/content/**",
        "content/**",
        "**/assets/js/project-data.js",
        "assets/js/project-data.js",
        "**/dev/**",
        "dev/**",
        "**/.wrangler/**",
        ".wrangler/**",
        "**/sitemap.xml",
        "**/robots.txt",
        "**/package.json",
        "**/package-lock.json",
        "**/wrangler.jsonc",
        "**/.gitignore",
        "**/README.md",
        "**/.r2_cache.json"
    ],
    "liveServer.settings.wait": 1000,
    "liveServer.settings.port": 5588,
    "liveServer.settings.donotVerifyTags": true,
    // --- Auto-Compilation Configuration ---
    // Using your already-installed "Trigger Task on Save" extension (gardne.trigger-task-on-save)
    // configured to run silently in the background without popups or alerts.
    "triggerTaskOnSave.on": true,
    "triggerTaskOnSave.showNotifications": false,
    "triggerTaskOnSave.tasks": {
        "Build Project Pages": [
            "**/content/*.html",
            "**/assets/js/project-data.js"
        ]
    }
}